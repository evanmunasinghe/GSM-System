{
  "openapi": "3.1.0",
  "info": {
    "title": "FleeV Garage Management API",
    "version": "1.0.0",
    "description": "Proposed API contract derived from the FleeV database migrations and ER diagram. Database CRUD controllers are not implemented yet. Tenant-scoped writes infer tenant_id from the authenticated tenant context."
  },
  "servers": [
    {
      "url": "http://{tenant}.localhost/api",
      "description": "Local tenant API",
      "variables": {
        "tenant": {
          "default": "davesautos",
          "description": "Tenant domain prefix"
        }
      }
    },
    {
      "url": "https://{tenant}.fleev.lk/api",
      "description": "Production tenant API",
      "variables": {
        "tenant": {
          "default": "demo",
          "description": "Tenant domain prefix"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Tenants" },
    { "name": "Users" },
    { "name": "Customers" },
    { "name": "Vehicles" },
    { "name": "Owners" },
    { "name": "Documents" },
    { "name": "Insurance" },
    { "name": "Facilities" },
    { "name": "Accessories" },
    { "name": "Maintenance" },
    { "name": "Repairs" },
    { "name": "Companies" }
  ],
  "paths": {
    "/tenants": {
      "get": {
        "tags": ["Tenants"],
        "summary": "List tenants",
        "operationId": "listTenants",
        "responses": {
          "200": {
            "description": "Tenant list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Tenant" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Tenants"],
        "summary": "Create a tenant",
        "operationId": "createTenant",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TenantWrite" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tenant created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Tenant" }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
